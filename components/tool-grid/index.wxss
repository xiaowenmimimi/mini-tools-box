@font-face {
  font-family: "tool-iconfont";
  src: url("https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/webfonts/fa-solid-900.woff2") format("woff2");
}

.tools-grid {
  display: grid;
  gap: 24rpx;
}

.tool-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.07);
  position: relative;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.tool-item:active {
  transform: scale(0.98);
}

.tool-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  height: 120rpx;
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f1f5f9 0%, #eef2ff 100%);
}

.tool-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 6rpx;
}

.tool-desc {
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.4;
}
