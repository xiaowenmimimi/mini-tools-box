<view class="tools-grid" style="grid-template-columns: repeat({{columns}}, 1fr);">
  <block wx:for="{{tools}}" wx:key="id">
    <view class="tool-item" bindtap="onToolClick" data-index="{{index}}">
      <view class="tool-icon {{item.iconClass || ''}}">{{item.icon}}</view>
      <view class="tool-name">{{item.name}}</view>
      <view class="tool-desc" wx:if="{{item.desc}}">{{item.desc}}</view>
    </view>
  </block>
</view>
