.tool-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  transition: transform 0.2s;
}

.tool-card:active {
  transform: scale(0.96);
}

.tool-icon {
  font-size: 60rpx;
  height: 120rpx;
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.tool-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.tool-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}
