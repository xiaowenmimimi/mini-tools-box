<view class="page-container">
  <view class="card step-container">
    <view class="step-badge">1</view>
    <view class="section-title">选择图片</view>
    <button class="btn btn-primary" bindtap="pick">
      <text class="iconfont">📷</text> 选择图片（最多15张）
    </button>
    <view class="status-row" style="margin-top:16rpx;">
      <view class="hint">支持多选导入，长按可拖动图片修改顺序</view>
      <view class="status-text">已选：{{list.length}}张</view>
    </view>
    
    <!-- 图片预览区 (网格布局) -->
    <view 
      class="image-preview-grid" 
      wx:if="{{list.length > 0}}"
      bindtouchmove="onDragMove"
      bindtouchend="onDragEnd"
    >
      <view 
        class="image-preview-item-wrapper"
        wx:for="{{list}}" 
        wx:key="uniqueKey" 
        style="{{(dragState.isDragging && dragState.dragItemInfo.index === index) ? 'visibility: ' + (dragState.isTempHidden ? 'hidden' : 'visible') + '; opacity: 0.3; border: 1px dashed #10B981;' : ''}}"
      >
        <view class="image-preview-item" bindlongpress="onDragStart" data-index="{{index}}">
          <image class="preview-thumbnail" src="{{item.path}}" mode="aspectFill"></image>
          <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 被拖拽的项的浮动克隆 -->
  <view 
    wx:if="{{dragState.isDragging && !dragState.isTempHidden}}"
    class="image-preview-item dragged-clone"
    style="left:{{dragState.dragItemInfo.x}}px; top:{{dragState.dragItemInfo.y}}px; width:{{dragState.dragItemInfo.width}}px; height:{{dragState.dragItemInfo.height}}px; transform: scale({{dragState.dragItemInfo.scale}}) rotate({{dragState.dragItemInfo.rotate}}deg);"
  >
    <image class="preview-thumbnail" src="{{dragState.dragItemInfo.path}}" mode="aspectFill"></image>
    <!-- 添加拖拽提示 -->
    <view class="drag-indicator">
      <text>拖动中</text>
    </view>
  </view>

  <block wx:if="{{list.length}}">
    <view class="card step-container">
      <view class="step-badge">2</view>
      <view class="section-title">预览与拼接</view>
      
      <view class="bg-select-section">
        <text class="section-subtitle">背景颜色</text>
        <view class="color-options">
          <!-- 预设颜色 -->
          <view 
            class="color-option {{!isCustomBgActive && bg === item.value ? 'active' : ''}}" 
            wx:for="{{bgOptions}}" 
            wx:key="value"
            bindtap="setBg" 
            data-color="{{item.value}}"
          >
            <view class="color-preview" style="background-color:{{item.value}}"></view>
            <text class="color-name">{{item.name}}</text>
          </view>
          
          <!-- 自定义颜色 -->
          <view 
            class="color-option {{isCustomBgActive ? 'active' : ''}}"
            bindtap="activateCustomBg"
          >
            <view class="color-preview custom-bg-icon">
              <text>🎨</text>
            </view>
            <text class="color-name">自定义</text>
          </view>
        </view>

        <!-- 自定义颜色区域 -->
        <view class="custom-color-area" wx:if="{{isCustomBgActive}}">
          <!-- 调色板 -->
          <view class="color-palette-wrapper">
            <view 
              class="palette-color-box {{bg === item ? 'active' : ''}}" 
              wx:for="{{colorPalette}}" 
              wx:key="*this"
              style="background-color: {{item}};"
              bindtap="selectPaletteColor"
              data-color="{{item}}"
            ></view>
          </view>
          <!-- HEX 输入框 -->
          <view class="custom-bg-input-wrapper">
            <view class="input-prefix">#</view>
            <input 
              class="custom-bg-input" 
              value="{{customBgInput}}" 
              maxlength="6"
              bindinput="onCustomBgInput"
            />
          </view>
        </view>

        <view class="bg-preview">
          <text>预览效果</text>
          <view class="bg-sample" style="background-color:{{bg}}">
            <text style="color:{{bg === '#000000' ? '#fff' : '#000'}}">ABC</text>
          </view>
        </view>
      </view>
      
      <view class="toolbar">
        <button class="btn btn-primary" bindtap="compose">开始拼接</button>

        <button class="btn btn-warning" bindtap="exportImg" wx:if="{{composed}}">导出图片</button>
      </view>
    </view>



    <view class="canvas-container" id="canvasBox">
      <!-- 隐藏的Canvas用于绘制 -->
      <canvas
        type="2d"
        id="cvs"
        style="width: 100%; height: {{previewH}}px; background:{{bg || '#ffffff'}}; border-radius:12rpx; {{previewLoading ? '' : 'display: none;'}}"
        disable-scroll="true" 
      ></canvas>
      
      <!-- 图片预览区域 -->
      <view class="preview-wrapper" wx:if="{{previewImageUrl && !previewError}}">
        <image 
          src="{{previewImageUrl}}" 
          mode="widthFix"
          class="preview-image"
          binderror="onPreviewImageError"
          bindload="onPreviewImageLoad"
        ></image>
        
        <!-- 加载状态提示 -->
        <view class="preview-loading" wx:if="{{previewLoading}}">
          <view class="loading-spinner"></view>
          <text>图片加载中...</text>
        </view>
      </view>
      
      <!-- 失败提示 -->
      <view class="preview-error-msg" wx:if="{{previewError}}">
        <view class="error-icon">⚠</view>
        <text>预览图片加载失败</text>
        <text class="error-hint">请直接导出图片查看效果</text>
      </view>
    </view>

  </block>
</view>
