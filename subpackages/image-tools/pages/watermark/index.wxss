.ui-section-title { margin-bottom: 20rpx; }
.status-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.status-gap { margin-top: 16rpx; }
.status-text { font-size: 26rpx; color: #475569; }
.image-preview-single { margin-top: 16rpx; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; background: #f1f5f9; border: 1rpx solid rgba(148,163,184,0.25); }
.preview-thumbnail { width: 100%; height: 100%; }
.field-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.label { font-size: 26rpx; color: #334155; min-width: 120rpx; font-weight: 600; }
.text-input { flex: 1; background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); border-radius: 12rpx; padding: 12rpx 16rpx; color: #0f172a; }
.num-input { width: 180rpx; background: #f3f4f6; border-radius: 8rpx; padding: 12rpx 16rpx; }
.radio-item { margin-right: 16rpx; }
.switches { gap: 40rpx; }
.switch-item { display: flex; align-items: center; gap: 12rpx; }
.logo-preview { width: 160rpx; height: 160rpx; border-radius: 8rpx; overflow: hidden; background: #f0f0f0; }
.logo-thumb { width: 100%; height: 100%; }
.color-palette { display: flex; flex-wrap: wrap; gap: 12rpx; }
.palette-color-box { width: 50rpx; height: 50rpx; border-radius: 10rpx; border: 2rpx solid transparent; box-shadow: 0 2rpx 6rpx rgba(15,23,42,0.12); }
.palette-color-box.active { border-color: #14b8a6; box-shadow: 0 8rpx 16rpx rgba(20,184,166,0.25); }
.custom-color-input { display: flex; align-items: center; background-color: #f8fafc; border-radius: 10rpx; padding: 8rpx 12rpx; border: 1rpx solid rgba(148,163,184,0.24); }
.input-prefix { font-size: 28rpx; color: #64748b; margin-right: 8rpx; }
.hex-input { font-size: 28rpx; width: 220rpx; font-family: monospace; }
.canvas-container { width: 100%; border-radius: 16rpx; overflow: hidden; box-shadow: 0 10rpx 26rpx rgba(15,23,42,0.1); margin: 8rpx 0 16rpx; border: 1rpx solid rgba(148,163,184,0.2); }

.pos-grid { flex: 1; }
.pos-grid-inner { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; width: 100%; }
.pos-btn { display: flex; align-items: center; justify-content: center; padding: 16rpx; border: 1rpx solid rgba(148,163,184,0.3); border-radius: 12rpx; background: #f8fafc; font-size: 26rpx; color: #1f2937; }
.pos-btn:active { background: #ecfeff; border-color: #5eead4; }

.range { position: relative; flex: 1; }
.range-track { position: absolute; top: 50%; transform: translateY(-50%); left: 0; right: 0; height: 12rpx; background: #e5e7eb; border-radius: 12rpx; pointer-events: none; z-index: 0; }
.range-fill { height: 100%; background: #10B981; border-radius: 12rpx; width: 0%; transition: width 0.1s linear; pointer-events: none; z-index: 0; }
.value-pill { position: absolute; right: 0; top: -48rpx; background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%); color: #fff; border-radius: 20rpx; padding: 6rpx 12rpx; font-size: 24rpx; pointer-events: none; z-index: 0; }
.toolbar { margin-top: 8rpx; }
