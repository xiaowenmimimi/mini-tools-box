.section-card {
  padding: 26rpx;
}

.tabs {
  margin-bottom: 16rpx;
  display: flex;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #475569;
  border-radius: 12rpx;
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  font-weight: 700;
}

.result-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.small-btn {
  margin: 0;
  min-width: 160rpx;
  height: 60rpx;
  line-height: 1.2;
  font-size: 24rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-box {
  margin-top: 16rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.code-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.code-item {
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  background: #ffffff;
  padding: 16rpx;
}

.code-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.code-name {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 600;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.code-meta {
  font-size: 21rpx;
  color: #64748b;
}

.code-value {
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.15;
  letter-spacing: 6rpx;
  color: #0f172a;
  font-weight: 700;
  font-family: monospace;
}

.code-foot {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 23rpx;
  color: #64748b;
}

.mini-copy-btn {
  margin: 0;
  min-width: 128rpx;
  height: 56rpx;
  line-height: 1.2;
  border-radius: 999rpx;
  font-size: 23rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-item {
  width: 100%;
  height: 76rpx;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  box-sizing: border-box;
  margin-top: 12rpx;
}

.secret-input {
  font-family: monospace;
}

.row-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.picker-item {
  height: 76rpx;
  border-radius: 12rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.picker-inner {
  height: 76rpx;
  line-height: 76rpx;
  font-size: 24rpx;
  color: #0f172a;
}

.toolbar {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-btn {
  flex: 1;
  margin: 0;
  height: 72rpx;
  line-height: 1.2;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-list-card {
  margin-top: 14rpx;
}

.account-count {
  font-size: 22rpx;
  color: #64748b;
}

.account-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.account-item {
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  padding: 14rpx;
  background: #ffffff;
}

.account-title {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
}

.account-sub {
  margin-top: 4rpx;
  font-size: 23rpx;
  color: #475569;
}

.account-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.account-secret {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #334155;
  font-family: monospace;
}

.account-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 21rpx;
  color: #94a3b8;
}

.account-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-secret-btn {
  margin: 0;
  min-width: 0;
  height: auto;
  line-height: normal;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #0f766e;
  background: #ccfbf1;
  border: none;
  padding: 6rpx 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 400;
}

.delete-btn {
  margin: 0;
  min-width: 0;
  height: auto;
  line-height: normal;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #b91c1c;
  background: #fee2e2;
  border: none;
  padding: 6rpx 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 400;
}

.copy-secret-btn:active,
.delete-btn:active {
  opacity: 0.7;
  transform: none;
}
