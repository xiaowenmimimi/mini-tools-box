.tabs {
  display: flex;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #475569;
  background: #f1f5f9;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
}

.tab-item.active {
  color: #0f766e;
  background: #ccfbf1;
  border-color: rgba(20, 184, 166, 0.5);
  font-weight: 600;
}

.tab-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.compact-main-card {
  gap: 10rpx;
}

.compact-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.compact-meta {
  font-size: 20rpx;
  white-space: nowrap;
}

.text-input,
.result-input {
  width: 100%;
  min-height: 156rpx;
  max-height: 320rpx;
  padding: 14rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  line-height: 1.55;
}

.pass-input {
  width: 100%;
  min-height: 72rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 24rpx;
}

.algo-picker {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
}

.picker-inner {
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
  color: #0f172a;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #475569;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #64748b;
  font-size: 22rpx;
}

.toolbar {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.action-btn {
  margin: 0;
  flex: 1;
  min-width: 160rpx;
  font-size: 24rpx;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.compact-actions {
  flex-wrap: nowrap;
}

.compact-action-btn {
  height: 68rpx;
  line-height: 68rpx;
}

.result-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex-wrap: wrap;
}

.compact {
  gap: 8rpx;
}

.small-btn {
  margin: 0;
  min-width: 132rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  padding: 0 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.compact-result-card {
  gap: 10rpx;
}

.history-card {
  gap: 14rpx;
}

.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-count {
  color: #64748b;
  font-size: 22rpx;
}

.history-toolbar {
  display: flex;
  justify-content: flex-end;
}

.tiny-btn {
  margin: 0;
  width: auto;
  min-width: 0;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-item {
  border: 1rpx solid rgba(148, 163, 184, 0.25);
  border-radius: 14rpx;
  background: #f8fafc;
  padding: 16rpx;
}

.history-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.history-tag {
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  font-weight: 600;
}

.encrypt-tag {
  background: #ccfbf1;
  color: #0f766e;
}

.decrypt-tag {
  background: #dbeafe;
  color: #1d4ed8;
}

.history-time {
  font-size: 22rpx;
  color: #64748b;
}

.history-payload {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #0f172a;
  word-break: break-all;
}

.history-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.history-btn {
  margin: 0;
  flex: 1;
  min-width: 0;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  background: #e2e8f0;
  color: #334155;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.history-btn::after {
  border: none;
}

.history-btn.danger {
  background: #fee2e2;
  color: #b91c1c;
}

.error-card {
  border-color: rgba(239, 68, 68, 0.32);
  background: #fef2f2;
}

.error-text {
  color: #b91c1c;
  font-size: 24rpx;
}
