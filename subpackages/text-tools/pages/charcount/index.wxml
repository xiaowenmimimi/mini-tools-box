<view class="page-shell">
  <view class="page-header ui-hero-glass">
    <view class="page-title">字符统计</view>
    <view class="page-subtitle">快速查看长度、单词、行数与字节信息</view>
  </view>
  <view class="card ui-soft-card section-card">
    <view class="ui-section-title">输入文本</view>
    <textarea class="text-input" placeholder="在此粘贴或输入文本..." value="{{text}}" auto-height="true" maxlength="-1" bindinput="onTextInput"></textarea>
    <view class="toolbar action-bar">
      <button class="btn ui-btn-primary" bindtap="copyStats">复制统计</button>
      <button class="btn ui-btn-warning" bindtap="clearText">清空</button>
    </view>
  </view>

  <view class="card ui-soft-card section-card">
    <view class="ui-section-title">统计结果</view>
    <view wx:if="{{text}}" class="stats-grid">
      <view class="stat-item"><view class="stat-name">字符数</view><view class="stat-value">{{stats.length}}</view></view>
      <view class="stat-item"><view class="stat-name">非空白字符</view><view class="stat-value">{{stats.nonSpace}}</view></view>
      <view class="stat-item"><view class="stat-name">单词数</view><view class="stat-value">{{stats.words}}</view></view>
      <view class="stat-item"><view class="stat-name">行数</view><view class="stat-value">{{stats.lines}}</view></view>
      <view class="stat-item"><view class="stat-name">空白字符</view><view class="stat-value">{{stats.spaces}}</view></view>
      <view class="stat-item"><view class="stat-name">换行数</view><view class="stat-value">{{stats.newlines}}</view></view>
      <view class="stat-item"><view class="stat-name">UTF-8字节</view><view class="stat-value">{{stats.bytes}}</view></view>
    </view>
    <view wx:else class="ui-empty">
      <view class="ui-empty-title">暂无统计结果</view>
      <view class="ui-empty-sub">输入文本后将自动展示统计数据</view>
    </view>
  </view>
</view>
