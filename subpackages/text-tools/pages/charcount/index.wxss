.page-container { padding: 24rpx; display: flex; flex-direction: column; gap: 24rpx; }
.section-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; color: #333; }
.text-input { width: 100%; min-height: 220rpx; background: #f3f4f6; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; }
.stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.stat-item { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12rpx; padding: 16rpx; display: flex; align-items: center; justify-content: space-between; }
.stat-name { font-size: 26rpx; color: #666; }
.stat-value { font-size: 30rpx; font-weight: 600; color: #111; }
.btn {
  background: #10B981;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  transition: all 0.2s;
}

.btn:active {
  background: #059669;
}

.btn-primary {
  background: #10B981;
}

.btn-warning {
  background: #ff9800;
}
