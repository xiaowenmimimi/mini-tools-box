<view class="page-shell">
  <view class="page-header ui-hero-glass">
    <view class="page-title">二维码工具</view>
    <view class="page-subtitle">生成、识别、历史记录一体化处理</view>
  </view>
  <view class="tabs">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="{{0}}">生成</view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="{{1}}">识别</view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="{{2}}">历史</view>
  </view>

  <!-- Generate Tab -->
  <view class="tab-content" wx:if="{{activeTab === 0}}">
    <view class="card ui-soft-card input-card">
      <view class="ui-section-title">输入内容</view>
      <textarea class="text-input" placeholder="输入文本或网址..." value="{{inputText}}" bindinput="onInput" maxlength="500"></textarea>
    </view>

    <view class="card ui-soft-card settings-card">
      <view class="ui-section-title">样式设置</view>
      
      <!-- 尺寸选择 -->
      <view class="setting-item column">
        <text class="label-block">尺寸 (px)</text>
        <view class="radio-group wrap">
          <view class="radio-btn {{sizeType === 'fixed' && size === 300 ? 'active' : ''}}" bindtap="onSizeSelect" data-size="{{300}}" data-type="fixed">300</view>
          <view class="radio-btn {{sizeType === 'fixed' && size === 400 ? 'active' : ''}}" bindtap="onSizeSelect" data-size="{{400}}" data-type="fixed">400</view>
          <view class="radio-btn {{sizeType === 'fixed' && size === 500 ? 'active' : ''}}" bindtap="onSizeSelect" data-size="{{500}}" data-type="fixed">500</view>
          <view class="radio-btn {{sizeType === 'custom' ? 'active' : ''}}" bindtap="onSizeSelect" data-size="{{customSize}}" data-type="custom">自定义</view>
        </view>
        <view wx:if="{{sizeType === 'custom'}}" class="custom-input-row">
          <input class="input-bordered ui-input-surface" type="number" value="{{customSize}}" bindinput="onCustomSizeInput" placeholder="输入尺寸(100-1000)" />
          <text>px</text>
        </view>
      </view>

      <!-- 码边距 -->
      <view class="setting-item column">
        <text class="label-block">码边距 (Quiet Zone)</text>
        <view class="radio-group">
          <view class="radio-btn {{marginType === 1 ? 'active' : ''}}" bindtap="onMarginSelect" data-margin="{{1}}">1个色块</view>
          <view class="radio-btn {{marginType === 2 ? 'active' : ''}}" bindtap="onMarginSelect" data-margin="{{2}}">2个色块</view>
          <view class="radio-btn {{marginType === 3 ? 'active' : ''}}" bindtap="onMarginSelect" data-margin="{{3}}">3个色块</view>
        </view>
      </view>

      <!-- 添加文字 -->
      <view class="setting-item column">
        <text class="label-block">添加文字</text>
        <view class="radio-group">
          <view class="radio-btn {{textLocation === 'none' ? 'active' : ''}}" bindtap="onTextLocationSelect" data-loc="none">无</view>
          <view class="radio-btn {{textLocation === 'top' ? 'active' : ''}}" bindtap="onTextLocationSelect" data-loc="top">码上</view>
          <view class="radio-btn {{textLocation === 'bottom' ? 'active' : ''}}" bindtap="onTextLocationSelect" data-loc="bottom">码下</view>
        </view>
        <view wx:if="{{textLocation !== 'none'}}" class="text-config-area">
          <input class="input-bordered full-width ui-input-surface" value="{{textContent}}" bindinput="onTextContentInput" placeholder="请输入显示的文字" />
          <view class="text-style-row">
            <view class="color-input-small">
               <text class="label-small">颜色</text>
               <view class="color-preview-dot" style="background: {{textColor}};"></view>
               <input class="color-input-text ui-input-surface" value="{{textColor}}" bindinput="onTextColorInput" placeholder="#000000"/>
            </view>
            <view class="size-input-small">
               <text class="label-small">大小</text>
               <input class="input-bordered small ui-input-surface" type="number" value="{{textSize}}" bindinput="onTextSizeInput" />
            </view>
          </view>
        </view>
      </view>

      <!-- 颜色设置 -->
      <view class="setting-item column">
        <view class="label-row">
          <text class="label-block">前景色</text>
          <view class="color-input-small">
             <view class="color-preview-dot" style="background: {{colorDark}};"></view>
             <input class="color-input-text ui-input-surface" value="{{colorDark}}" bindinput="onColorDarkChange" placeholder="#000000"/>
          </view>
        </view>
        <scroll-view scroll-x enable-flex class="color-scroll">
          <view class="color-list">
            <view wx:for="{{colorPresets}}" wx:key="*this" 
                  class="color-opt {{colorDark === item ? 'active' : ''}}" 
                  bindtap="onColorDarkPreset" 
                  data-color="{{item}}" 
                  style="background:{{item}}; border:{{item==='#ffffff'?'1rpx solid #ddd':'none'}};"></view>
          </view>
        </scroll-view>
      </view>

      <view class="setting-item column">
        <view class="label-row">
          <text class="label-block">背景色</text>
          <view class="color-input-small">
             <view class="color-preview-dot" style="background: {{colorLight}};"></view>
             <input class="color-input-text ui-input-surface" value="{{colorLight}}" bindinput="onColorLightChange" placeholder="#ffffff"/>
          </view>
        </view>
        <scroll-view scroll-x enable-flex class="color-scroll">
          <view class="color-list">
            <view wx:for="{{colorPresets}}" wx:key="*this" 
                  class="color-opt {{colorLight === item ? 'active' : ''}}" 
                  bindtap="onColorLightPreset" 
                  data-color="{{item}}" 
                  style="background:{{item}}; border:{{item==='#ffffff'?'1rpx solid #ddd':'none'}};"></view>
          </view>
        </scroll-view>
      </view>

      <view class="setting-item">
        <text class="label">Logo (可选)</text>
        <view class="logo-uploader" bindtap="chooseLogo">
          <image wx:if="{{logoPath}}" src="{{logoPath}}" mode="aspectFit" class="logo-preview"></image>
          <view wx:else class="upload-placeholder">+</view>
        </view>
        <view wx:if="{{logoPath}}" class="clear-btn" catchtap="clearLogo">清除</view>
      </view>
    </view>

    <view class="card ui-soft-card preview-card">
      <view class="ui-section-title">效果预览</view>
      <image wx:if="{{previewImg}}" src="{{previewImg}}" mode="aspectFit" class="preview-image" bindtap="previewBigImage"></image>
      <view wx:elif="{{inputText}}" class="preview-loading">
        <text>生成中...</text>
      </view>
      <view wx:else class="ui-empty">
        <view class="ui-empty-title">等待生成预览</view>
        <view class="ui-empty-sub">输入文本后点击“生成预览”</view>
      </view>
    </view>

    <!-- Hidden Canvas for Generation -->
    <view style="position: fixed; left: -9999px; top: -9999px;">
      <canvas canvas-id="qrcodeCanvas" style="width: {{canvasWidth || size}}px; height: {{canvasHeight || size}}px;"></canvas>
    </view>

    <view class="action-bar">
      <button class="btn ui-btn-primary" bindtap="generateQR">生成预览</button>
      <button class="btn ui-btn-outline" bindtap="saveImage">保存图片</button>
    </view>
  </view>

  <!-- Recognize Tab -->
  <view class="tab-content" wx:if="{{activeTab === 1}}">
    <view class="card ui-soft-card">
      <view class="ui-section-title">识别方式</view>
    <view class="scan-actions">
      <view class="scan-btn-large" bindtap="scanCode">
        <view class="icon-scan">📷</view>
        <text>扫码识别</text>
      </view>
      <view class="scan-btn-large" bindtap="chooseImageScan">
        <view class="icon-image">🖼️</view>
        <text>相册识别</text>
      </view>
    </view>
    </view>

    <view class="card ui-soft-card result-card" wx:if="{{scanResult}}">
      <view class="ui-section-title">识别结果</view>
      <text class="result-text" user-select>{{scanResult}}</text>
      <view class="result-actions">
        <button class="btn btn-sm ui-btn-primary" bindtap="copyResult">复制</button>
        <button class="btn btn-sm ui-btn-warning" wx:if="{{isUrl}}" bindtap="openLink">打开链接</button>
      </view>
    </view>
  </view>

  <!-- History Tab -->
  <view class="tab-content" wx:if="{{activeTab === 2}}">
    <view class="history-list">
      <block wx:if="{{historyList.length > 0}}">
        <view class="history-item" wx:for="{{historyList}}" wx:key="timestamp">
          <view class="history-info" bindtap="viewHistoryItem" data-item="{{item}}">
            <view class="history-type {{item.type === 'gen' ? 'type-gen' : 'type-scan'}}">{{item.type === 'gen' ? '生成' : '识别'}}</view>
            <view class="history-content">{{item.content}}</view>
            <view class="history-date">{{item.date}}</view>
          </view>
          <view class="history-delete" bindtap="deleteHistoryItem" data-index="{{index}}">×</view>
        </view>
      </block>
      <view wx:else class="ui-empty">
        <view class="ui-empty-title">暂无历史记录</view>
        <view class="ui-empty-sub">生成或识别后会自动保存</view>
      </view>
    </view>
    <view wx:if="{{historyList.length > 0}}" class="clear-history-btn" bindtap="clearHistory">清空历史</view>
  </view>
</view>
