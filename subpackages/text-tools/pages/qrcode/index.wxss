/* subpackages/text-tools/pages/qrcode/index.wxss */
.page-container {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #10B981;
  color: #fff;
  font-weight: 600;
}

/* Content */
.tab-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* Input */
.text-input {
  width: 100%;
  min-height: 160rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* Settings */
.section-header {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333;
  border-left: 6rpx solid #10B981;
  padding-left: 16rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.setting-item.column {
  flex-direction: column;
  align-items: flex-start;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #444;
  width: 180rpx;
}

.label-block {
  font-size: 28rpx;
  color: #444;
  margin-bottom: 16rpx;
  display: block;
}

/* Radio Group (Size) */
.radio-group {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.radio-group.wrap {
  flex-wrap: wrap;
}

.radio-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  background: #f3f4f6;
  border-radius: 12rpx;
  border: 1px solid transparent;
  transition: all 0.2s;
  min-width: 120rpx; /* 防止太窄 */
}

/* Custom Input */
.custom-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  margin-top: 16rpx;
}

.input-bordered {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  background: #fff;
}

.custom-input-row .input-bordered {
  flex: 1;
}

/* Text Config */
.text-config-area {
  width: 100%;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #f9fafb;
  padding: 16rpx;
  border-radius: 12rpx;
}

.full-width {
  width: 100%;
  box-sizing: border-box;
}

.text-style-row {
  display: flex;
  gap: 24rpx;
}

.size-input-small {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 6rpx 16rpx;
  border: 1px solid #eee;
}

.size-input-small .input-bordered.small {
  width: 80rpx;
  border: none;
  background: transparent;
  padding: 0 8rpx;
  text-align: center;
}

.label-small {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.radio-btn.active {
  background: #e6fffa;
  color: #10B981;
  border-color: #10B981;
  font-weight: 500;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  margin-bottom: 16rpx;
}

.color-input-small {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 24rpx;
  padding: 6rpx 16rpx;
}

.color-preview-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 1px solid rgba(0,0,0,0.1);
}

.color-input-text {
  font-size: 24rpx;
  color: #666;
  width: 120rpx;
}

/* Color Options */
.color-scroll {
  width: 100%;
  white-space: nowrap;
}

.color-list {
  display: flex;
  gap: 20rpx;
  padding: 4rpx 2rpx;
}

.color-opt {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
  position: relative;
  transition: transform 0.2s;
  flex-shrink: 0;
}

.logo-uploader {
  width: 100rpx;
  height: 100rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1px dashed #ccc;
}

.upload-placeholder {
  font-size: 48rpx;
  color: #999;
}

.logo-preview {
  width: 100%;
  height: 100%;
}

.clear-btn {
  font-size: 24rpx;
  color: #ef4444;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  background: #fee2e2;
  border-radius: 8rpx;
}

/* Preview */
.preview-card {
  display: flex;
  justify-content: center;
  align-items: center;
  background: #fff;
  min-height: 500rpx; /* 固定高度，确保显示区域 */
  padding: 40rpx;
  box-sizing: border-box;
}

.preview-image {
  width: 100%;
  height: 420rpx; /* 限制显示高度，保持比例 */
  display: block;
}

.preview-loading {
  color: #999;
  font-size: 28rpx;
}

.qrcode-canvas {
  background: #fff;
}

/* Action Bar */
.action-bar {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  background: #10B981;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
  transition: all 0.2s;
}

.btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-outline {
  background: #fff;
  color: #10B981;
  border: 1px solid #10B981;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  flex: none;
}

.btn-warning {
  background: #f59e0b;
}

/* Scan Actions */
.scan-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 40rpx;
}

.scan-btn-large {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  height: 240rpx;
}

.scan-btn-large:active {
  background: #f9fafb;
}

.icon-scan, .icon-image {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

/* Result Card */
.result-card {
  margin-top: 24rpx;
}

.result-header {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.result-text {
  display: block;
  font-size: 32rpx;
  color: #111;
  background: #f9fafb;
  padding: 24rpx;
  border-radius: 12rpx;
  word-break: break-all;
  margin-bottom: 24rpx;
}

.result-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

/* History */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.history-info {
  flex: 1;
  overflow: hidden;
}

.history-type {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.type-gen {
  background: #d1fae5;
  color: #059669;
}

.type-scan {
  background: #e0f2fe;
  color: #0284c7;
}

.history-content {
  font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 4rpx;
}

.history-date {
  font-size: 22rpx;
  color: #999;
}

.history-delete {
  padding: 16rpx;
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.clear-history-btn {
  text-align: center;
  padding: 24rpx;
  color: #666;
  font-size: 26rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  margin-top: 24rpx;
}
