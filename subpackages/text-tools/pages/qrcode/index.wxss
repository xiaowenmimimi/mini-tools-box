.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 12rpx;
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
  color: #ffffff;
  font-weight: 700;
}

/* Content */
.tab-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.input-card,
.settings-card,
.preview-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.text-input {
  width: 100%;
  min-height: 160rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #0f172a;
  border: 1rpx solid rgba(148, 163, 184, 0.25);
}

.section-header {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #0f172a;
  border-left: 6rpx solid #0ea5a4;
  padding-left: 16rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.setting-item.column {
  flex-direction: column;
  align-items: flex-start;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #334155;
  width: 180rpx;
  font-weight: 600;
}

.label-block {
  font-size: 28rpx;
  color: #334155;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 600;
}

/* Radio Group (Size) */
.radio-group {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.radio-group.wrap {
  flex-wrap: wrap;
}

.radio-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #64748b;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.25);
  min-width: 120rpx;
}

/* Custom Input */
.custom-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  margin-top: 16rpx;
}

.input-bordered {
  border: 1rpx solid rgba(148, 163, 184, 0.3);
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #0f172a;
}

.custom-input-row .input-bordered {
  flex: 1;
}

/* Text Config */
.text-config-area {
  width: 100%;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #f8fafc;
  padding: 16rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
}

.full-width {
  width: 100%;
  box-sizing: border-box;
}

.text-style-row {
  display: flex;
  gap: 24rpx;
}

.size-input-small {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.25);
}

.size-input-small .input-bordered.small {
  width: 80rpx;
  border: none;
  background: transparent;
  padding: 0 8rpx;
  text-align: center;
}

.label-small {
  font-size: 24rpx;
  color: #64748b;
  margin-right: 8rpx;
}

.radio-btn.active {
  background: #ccfbf1;
  color: #0f766e;
  border-color: rgba(20, 184, 166, 0.7);
  font-weight: 700;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  margin-bottom: 16rpx;
}

.color-input-small {
  display: flex;
  align-items: center;
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.25);
}

.color-preview-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
}

.color-input-text {
  font-size: 24rpx;
  color: #334155;
  width: 120rpx;
  border-radius: 8rpx;
  padding: 6rpx 8rpx;
  border: none;
}

/* Color Options */
.color-scroll {
  width: 100%;
  white-space: nowrap;
}

.color-list {
  display: flex;
  gap: 20rpx;
  padding: 4rpx 2rpx;
}

.color-opt {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(15, 23, 42, 0.16);
  position: relative;
  flex-shrink: 0;
}

.logo-uploader {
  width: 100rpx;
  height: 100rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1rpx dashed rgba(148, 163, 184, 0.8);
}

.upload-placeholder {
  font-size: 48rpx;
  color: #94a3b8;
}

.logo-preview {
  width: 100%;
  height: 100%;
}

.clear-btn {
  font-size: 24rpx;
  color: #be123c;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  background: #ffe4e6;
  border-radius: 8rpx;
}

.preview-card {
  justify-content: center;
  align-items: stretch;
  background: #ffffff;
  min-height: 500rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.preview-image {
  width: 100%;
  height: 420rpx; /* 限制显示高度，保持比例 */
  display: block;
}

.preview-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 360rpx;
  color: #64748b;
  font-size: 28rpx;
}

.qrcode-canvas {
  background: #fff;
}

.action-bar {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  color: inherit;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
  font-weight: 600;
}

.btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  flex: none;
  min-width: 140rpx;
}

.scan-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 40rpx;
}

.scan-btn-large {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
  height: 240rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
}

.scan-btn-large:active {
  background: #f8fafc;
}

.icon-scan, .icon-image {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

/* Result Card */
.result-card {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-header {
  font-size: 28rpx;
  color: #334155;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.result-text {
  display: block;
  font-size: 32rpx;
  color: #0f172a;
  background: #f8fafc;
  padding: 24rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  word-break: break-all;
  margin-bottom: 24rpx;
}

.result-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

/* History */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.history-info {
  flex: 1;
  overflow: hidden;
}

.history-type {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.type-gen {
  background: #ccfbf1;
  color: #0f766e;
}

.type-scan {
  background: #dbeafe;
  color: #1d4ed8;
}

.history-content {
  font-size: 28rpx;
  color: #1f2937;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 4rpx;
}

.history-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.history-delete {
  padding: 16rpx;
  font-size: 40rpx;
  color: #94a3b8;
  line-height: 1;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: #94a3b8;
  font-size: 28rpx;
}

.clear-history-btn {
  text-align: center;
  padding: 24rpx;
  color: #334155;
  font-size: 26rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  margin-top: 24rpx;
}
