.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.label {
  font-size: 28rpx;
  color: #334155;
  font-weight: 700;
}

.picker-btn {
  font-size: 28rpx;
  color: #0f766e;
  background: linear-gradient(135deg, #ccfbf1 0%, #99f6e4 100%);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-weight: 600;
}

.text-input {
  width: 100%;
  min-height: 120rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 32rpx;
  font-family: monospace;
  box-sizing: border-box;
  color: #0f172a;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.clear-btn {
  font-size: 26rpx;
  color: #64748b;
  background: #f8fafc;
  border-radius: 8rpx;
  padding: 8rpx 18rpx;
}

.control-row {
  display: flex;
  justify-content: flex-end;
  padding: 18rpx 24rpx;
}

.format-switch {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #94a3b8;
  border-radius: 6rpx;
  position: relative;
}

.checkbox.checked {
  background: #0ea5a4;
  border-color: #0ea5a4;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 8rpx;
  height: 16rpx;
  border: solid #fff;
  border-width: 0 4rpx 4rpx 0;
  transform: rotate(45deg);
}

.output-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.result-content {
  font-size: 30rpx;
  color: #0f172a;
  font-family: monospace;
  word-break: break-all;
  line-height: 1.5;
}

.btn-copy-small {
  font-size: 22rpx;
  color: #0f766e;
  background: #ccfbf1;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.btn-copy-small:active {
  opacity: 0.7;
}

.error-card {
  background: #fff1f2;
}

.ui-section-title {
  margin-bottom: 20rpx;
}

.base-table {
  width: 100%;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  border-radius: 12rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  background: #f8fafc;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.28);
}

.table-header text {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #475569;
  border-right: 1rpx solid rgba(148, 163, 184, 0.28);
}

.table-header text:last-child {
  border-right: none;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.2);
}

.table-row:last-child {
  border-bottom: none;
}

.table-row text {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #1f2937;
  font-family: monospace;
  border-right: 1rpx solid rgba(148, 163, 184, 0.2);
}

.table-row text:last-child {
  border-right: none;
}
