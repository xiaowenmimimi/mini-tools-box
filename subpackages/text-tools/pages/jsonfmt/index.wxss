.section-card {
  padding: 26rpx;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.indent-pill {
  font-size: 24rpx;
  color: #0f766e;
  background: linear-gradient(135deg, #ccfbf1 0%, #99f6e4 100%);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-weight: 600;
}

.text-input {
  width: 100%;
  min-height: 240rpx;
  border-radius: 16rpx;
  padding: 18rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.action-bar {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.action-btn {
  min-width: 140rpx;
  padding: 12rpx 18rpx;
  font-size: 26rpx;
  line-height: 1.2;
}

.error-card {
  border: 1rpx solid rgba(239, 68, 68, 0.35);
  background: linear-gradient(160deg, #fff1f2 0%, #ffffff 100%);
}

.error-text {
  color: #b91c1c;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.copy-btn {
  min-width: 120rpx;
  padding: 10rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

.result-box {
  border-radius: 14rpx;
  padding: 18rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.26);
}

.result-text {
  font-size: 25rpx;
  color: #0f172a;
  font-family: monospace;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}
