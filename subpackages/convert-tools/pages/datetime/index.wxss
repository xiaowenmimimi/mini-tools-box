.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 12rpx;
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
  color: #ffffff;
  font-weight: 700;
}

.sub-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 6rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.sub-tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 10rpx;
  font-weight: 600;
}

.sub-tab-item.active {
  background: #d1fae5;
  color: #047857;
}

.input-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ui-section-title {
  margin-bottom: 10rpx;
}

.field-label {
  font-size: 24rpx;
  color: #475569;
  margin-top: 8rpx;
}

.input-control {
  width: 100%;
  height: 82rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #0f172a;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
}

.picker-btn {
  height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.24);
}

.flow-hint {
  font-size: 22rpx;
  color: #64748b;
}

.toolbar {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn {
  flex: 1;
  min-width: 180rpx;
}

.output-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.result-content {
  font-size: 30rpx;
  color: #0f172a;
  font-family: monospace;
  word-break: break-all;
  line-height: 1.5;
}

.btn-copy-small {
  font-size: 22rpx;
  color: #0f766e;
  background: #ccfbf1;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.btn-copy-small:active {
  opacity: 0.7;
}

.error-card {
  background: #fff1f2;
}

.error-text {
  color: #be123c;
  font-size: 26rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-actions {
  display: flex;
}

.history-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-mode {
  font-size: 24rpx;
  color: #0f766e;
  background: #ccfbf1;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
}

.history-time {
  font-size: 22rpx;
  color: #64748b;
}

.history-input {
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.5;
  word-break: break-all;
}

.history-offset {
  font-size: 24rpx;
  color: #334155;
}

.history-toolbar {
  display: flex;
  gap: 12rpx;
}

.history-btn {
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #0f766e;
  background: #ccfbf1;
}

.history-btn.danger {
  color: #be123c;
  background: #ffe4e6;
}
