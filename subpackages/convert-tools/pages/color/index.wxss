.input-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ui-section-title {
  margin-bottom: 8rpx;
}

.input-error-banner {
  background: #fff1f2;
  border: 1rpx solid #fecdd3;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.input-error-text {
  color: #be123c;
  font-size: 24rpx;
  line-height: 1.5;
}

.picker-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  background: #f8fafc;
}

.picker-entry-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-entry-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(15, 23, 42, 0.16);
}

.picker-entry-text {
  font-size: 24rpx;
  color: #334155;
}

.picker-entry-arrow {
  font-size: 32rpx;
  color: #64748b;
  line-height: 1;
}

.field-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
}

.input-control {
  width: 100%;
  height: 82rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #0f172a;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  font-family: monospace;
}

.output-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.preview-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
}

.preview-color {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.26);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.45);
}

.preview-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.preview-hex {
  font-size: 32rpx;
  color: #0f172a;
  font-family: monospace;
  font-weight: 700;
}

.preview-tip {
  font-size: 22rpx;
  color: #64748b;
}

.result-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  background: #ffffff;
}

.result-title {
  width: 70rpx;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 700;
}

.result-value {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
  font-family: monospace;
  word-break: break-all;
}

.btn-copy-small {
  font-size: 22rpx;
  color: #0f766e;
  background: #ccfbf1;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.btn-copy-small:active {
  opacity: 0.7;
}

.palette-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.palette-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.palette-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(148, 163, 184, 0.4);
}

.palette-item.active {
  transform: scale(1.08);
  border-color: rgba(15, 23, 42, 0.5);
  box-shadow: 0 0 0 6rpx rgba(16, 185, 129, 0.14);
}

.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.48);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.picker-close {
  font-size: 24rpx;
  color: #64748b;
}

.sv-panel {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.sv-white-layer {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, #ffffff 0%, rgba(255, 255, 255, 0) 100%);
}

.sv-black-layer {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, #000000 100%);
}

.sv-cursor {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 0 2rpx rgba(15, 23, 42, 0.3);
}

.hue-bar {
  position: relative;
  width: 100%;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff0000 0%, #ffff00 16.6%, #00ff00 33.2%, #00ffff 49.8%, #0000ff 66.4%, #ff00ff 83%, #ff0000 100%);
}

.hue-cursor {
  position: absolute;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 0 2rpx rgba(15, 23, 42, 0.3);
  background: transparent;
}

.picker-values {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.picker-preview {
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.35);
}

.picker-value-text {
  font-size: 28rpx;
  font-family: monospace;
  color: #0f172a;
  font-weight: 700;
}

.picker-hsv-text {
  margin-left: auto;
  font-size: 22rpx;
  color: #64748b;
}

.picker-actions {
  display: flex;
  gap: 16rpx;
}

.picker-btn {
  flex: 1;
}
