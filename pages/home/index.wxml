<view class="page-shell">
  <view class="page-header ui-hero-glass home-hero">
    <view class="page-title">Mini Tools Box</view>
    <view class="page-subtitle">常用工具集合，快速进入文本与图像处理场景</view>
    <view class="hero-meta">
      <view class="ui-pill ui-pill-success">{{tools.length}} 个工具箱</view>
      <view class="ui-pill ui-pill-info">持续更新中</view>
    </view>
  </view>
  <view class="card ui-soft-card">
    <view class="ui-section-title">功能入口</view>
    <view class="tools-grid">
    <block wx:for="{{tools}}" wx:key="id">
      <view class="tool-item" bindtap="goTool" data-index="{{index}}">
        <view class="tool-icon-wrap">
          <view class="tool-icon">{{item.icon}}</view>
        </view>
        <view class="tool-name">{{item.name}}</view>
        <view class="tool-desc">{{item.id === 'image' ? '拼接 / 水印 / 证件照' : '字符 / 二维码 / Cron / 进制'}}</view>
      </view>
    </block>
    </view>
  </view>
  <view class="hint">选择一个工具箱开始处理</view>
</view>
