@font-face {
  font-family: "tool-iconfont";
  src: url("https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/webfonts/fa-solid-900.woff2") format("woff2");
}

.home-hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-meta {
  margin-top: 10rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 20rpx 0 0;
}

.tool-item {
  background: linear-gradient(165deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 20rpx;
  padding: 34rpx 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.09);
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  aspect-ratio: 1/1;
}

.tool-item:active {
  transform: scale(0.98);
}

.tool-icon-wrap {
  width: 130rpx;
  height: 130rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #ecfeff 0%, #dbeafe 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
}

.tool-icon {
  font-size: 70rpx;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.tool-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.4;
}
